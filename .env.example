# Grantless environment overrides. Copy to `.env.local` (gitignored) to use.
# Every value here is an OPTIONAL, overridable convenience — none is required and
# none confers special status on any relay (Grantless prime directive).

# Point the app at a specific relay on startup. When unset, the app uses its
# normal default relay set (the RelaySelector UI still works either way).
# `npm run dev` defaults this to the local strfry that `npm run seed` fills;
# set it here to browse a different relay instead.
# VITE_RELAY_URL=ws://127.0.0.1:7787

# Optional curator allow-list for the curator picker, as a comma-separated list
# of npub… or 64-char hex pubkeys. These are MERGED with the curators discovered
# on the relay (anyone who published a grantless-applicants list) — they are a
# plain convenience, never privileged, and the default (unset) is discovery only.
# VITE_GRANTLESS_CURATORS=npub1xxxx...,npub1yyyy...
